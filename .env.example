APP_NAME="Tus Envios"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tusenvios.com.co

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

DEPLOY_KEY=cambia_esta_clave_por_una_segura

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=mail.tusenvios.com.co
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@tusenvios.com.co"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Carrier API (para integracion con transportadoras) ───
CARRIER_API_KEY=

# ─── Bold (pasarela de pagos) ───
BOLD_API_KEY=
BOLD_BASE_URL=https://integrations.api.bold.co

# ─── WhatsApp / Facebook API ───
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

VITE_APP_NAME="${APP_NAME}"
