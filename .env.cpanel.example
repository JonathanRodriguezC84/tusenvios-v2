APP_NAME="Tus Envios"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tusenvios.com.co

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CPANEL_USUARIO_tusenvios
DB_USERNAME=CPANEL_USUARIO_tusenvios
DB_PASSWORD=CAMBIAR_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.tusenvios.com.co

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=mail.tusenvios.com.co
MAIL_PORT=465
MAIL_USERNAME=no-reply@tusenvios.com.co
MAIL_PASSWORD=CAMBIAR_PASSWORD_CORREO
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@tusenvios.com.co
MAIL_FROM_NAME="${APP_NAME}"

BOLD_API_KEY=CAMBIAR_API_KEY_BOLD
BOLD_BASE_URL=https://integrations.api.bold.co

VITE_APP_NAME="${APP_NAME}"
